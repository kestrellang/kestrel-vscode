{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kestrel",
  "scopeName": "source.kestrel",
  "fileTypes": ["ks"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#decorators" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.kestrel",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.kestrel",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kestrel",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.kestrel",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.kestrel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kestrel",
              "match": "\\\\(?:[\\\\\"nrt0]|u\\{[0-9A-Fa-f]+\\})"
            },
            {
              "name": "meta.embedded.line.kestrel",
              "begin": "\\\\\\(",
              "end": "\\)",
              "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.kestrel" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.kestrel" }
              },
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kestrel",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.kestrel",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.kestrel",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.kestrel",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.kestrel",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.attribute.kestrel",
          "match": "@[A-Za-z_][A-Za-z0-9_]*",
          "captures": {
            "0": { "name": "entity.name.function.decorator.kestrel" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kestrel",
          "match": "\\b(if|else|match|for|while|loop|in|return|break|continue|guard|throw|throws|try|defer|do|where|case)\\b"
        },
        {
          "name": "keyword.operator.logical.kestrel",
          "match": "\\b(and|or|not|as)\\b"
        },
        {
          "name": "keyword.declaration.kestrel",
          "match": "\\b(module|import|struct|enum|protocol|extend|extension|func|init|deinit|var|let|type|subscript)\\b"
        },
        {
          "name": "storage.modifier.kestrel",
          "match": "\\b(public|private|fileprivate|internal|static|mutating|consuming|indirect|get|set)\\b"
        },
        {
          "name": "constant.language.kestrel",
          "match": "\\b(true|false|null|self|Self|it)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.kestrel" },
            "2": { "name": "entity.name.function.kestrel" }
          }
        },
        {
          "match": "\\b(struct|enum|protocol|extend|extension)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.kestrel" },
            "2": { "name": "entity.name.type.kestrel" }
          }
        },
        {
          "match": "\\b(module)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.declaration.kestrel" },
            "2": { "name": "entity.name.namespace.kestrel" }
          }
        },
        {
          "match": "\\b(import)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.declaration.kestrel" },
            "2": { "name": "entity.name.namespace.kestrel" }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.kestrel",
          "match": "\\b(Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64|Float32|Float64|Bool|String|Char|Array|Optional|Result|Range)\\b"
        },
        {
          "name": "entity.name.type.kestrel",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.kestrel",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.range.kestrel",
          "match": "\\.\\.[<.]?"
        },
        {
          "name": "keyword.operator.assignment.kestrel",
          "match": "(\\+|\\-|\\*|/|%|&|\\||\\^|<<|>>)?="
        },
        {
          "name": "keyword.operator.comparison.kestrel",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.kestrel",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.kestrel",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.kestrel",
          "match": "&|\\||\\^|~|<<|>>"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.terminator.kestrel", "match": ";" },
        { "name": "punctuation.separator.kestrel", "match": "[,:.]" },
        { "name": "punctuation.section.brackets.kestrel", "match": "[\\[\\]\\(\\)\\{\\}]" }
      ]
    }
  }
}
